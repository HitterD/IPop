@page "/login"
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@using MudBlazor
@inject NavigationManager Nav

<PageTitle>Login — IPop</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-10">
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h4" Color="Color.Primary" Class="mb-4">Sign in</MudText>
        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
        }
        <form method="post" action="/auth/signin">
            <input type="hidden" name="returnUrl" value="@_returnUrl" />
            <MudTextField T="string" Label="NIK" name="nik" Required="true" RequiredError="NIK is required" />
            <MudTextField T="string" Label="Password" name="password" InputType="InputType.Password" Required="true" RequiredError="Password is required" Class="mt-3" />
            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="mt-6" FullWidth="true">
                Sign in
            </MudButton>
        </form>
    </MudPaper>
</MudContainer>

@code {
    private string? _error;
    private string _returnUrl = "/";

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("error", out var err))
        {
            _error = err.ToString();
        }
        if (query.TryGetValue("returnUrl", out var back))
        {
            var candidate = back.ToString();
            if (!string.IsNullOrWhiteSpace(candidate) && Uri.IsWellFormedUriString(candidate, UriKind.Relative))
            {
                _returnUrl = candidate;
            }
        }
    }
}
